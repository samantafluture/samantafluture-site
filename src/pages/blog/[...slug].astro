---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const stream = await getCollection('stream', ({ data }) => {
    return data.type === 'writing' && !!data.title && !data.draft;
  });

  const sorted = stream.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return sorted.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: sorted[i + 1] ? { slug: sorted[i + 1].id, title: sorted[i + 1].data.title! } : null,
      next: sorted[i - 1] ? { slug: sorted[i - 1].id, title: sorted[i - 1].data.title! } : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
---

<BlogLayout
  title={entry.data.title!}
  description={entry.data.excerpt || ''}
  date={entry.data.date}
  prev={prev}
  next={next}
>
  <Content />
</BlogLayout>
