---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Samanta Fluture — Senior Frontend Lead"
  description="Senior frontend lead and AI-native developer. React, TypeScript, GraphQL. Building production systems where AI does the heavy lifting."
>
  <!-- Position Indicator (desktop) -->
  <nav class="position-indicator" aria-label="Page sections">
    <button class="position-indicator__dot is-active" data-target="header" aria-label="Go to top"></button>
    <div class="position-indicator__line" aria-hidden="true"></div>
    <button class="position-indicator__dot" data-target="brief" aria-label="Go to summary"></button>
    <div class="position-indicator__line" aria-hidden="true"></div>
    <button class="position-indicator__dot" data-target="experience" aria-label="Go to experience"></button>
    <div class="position-indicator__line" aria-hidden="true"></div>
    <button class="position-indicator__dot" data-target="projects" aria-label="Go to projects"></button>
    <div class="position-indicator__line" aria-hidden="true"></div>
    <button class="position-indicator__dot" data-target="skills" aria-label="Go to skills"></button>
    <div class="position-indicator__line" aria-hidden="true"></div>
    <button class="position-indicator__dot" data-target="appendix" aria-label="Go to education"></button>
    <div class="position-indicator__line" aria-hidden="true"></div>
    <button class="position-indicator__dot" data-target="contact" aria-label="Go to contact"></button>
  </nav>

  <div class="page">

    <!-- ================================================================
         FILE HEADER
         ================================================================ -->
    <header class="header" data-section="header">
      <hr class="rule" />
      <div class="reveal">
        <h1 class="header__name">Samanta Fluture</h1>
        <div class="header__meta">
          <span class="header__role">Senior Frontend Lead</span>
          <span class="header__role">AI-Native Developer</span>
          <span class="header__location">Montreal, Canada</span>
        </div>
      </div>
      <hr class="header__rule" />
      <p class="header__thesis reveal">
        I build frontend systems at scale and ship
        <span class="redact" role="img" aria-label="media artist">
          <span class="redact__text">media artist</span>
          <span class="redact__bar" aria-hidden="true"></span>
        </span>-grade
        side projects where AI does the real work.
      </p>
    </header>

    <!-- ================================================================
         BRIEF
         ================================================================ -->
    <section class="section" data-section="brief">
      <div class="section__content">
        <span class="section__label reveal">Summary</span>
        <p class="brief__text reveal">
          Front-end lead at Turbulent, where I run a team building React and TypeScript
          interfaces on GraphQL. Code reviews, technical roadmaps, sprint cadence, mentoring.
          After hours I build AI-first products: a doc generator powered by Gemini, a
          self-hosted agent platform on a $10/month VPS, a business automation system where
          <span class="redact" role="img" aria-label="eleven Claude Code skills">
            <span class="redact__text">eleven Claude Code skills</span>
            <span class="redact__bar" aria-hidden="true"></span>
          </span>
          replace traditional app features. Four spoken languages, a Master's in
          digital design, and a background that runs from content strategy to
          interactive installations to Arduino workshops in public schools.
        </p>
      </div>
    </section>

    <!-- ================================================================
         EXPERIENCE
         ================================================================ -->
    <section class="section" data-section="experience">
      <div class="section__content">
        <span class="section__label reveal">Experience</span>

        <div class="experience-list reveal-stagger">

          <article class="experience-item reveal">
            <span class="experience-item__number">Role 08</span>
            <h2 class="experience-item__company">Turbulent</h2>
            <p class="experience-item__role">Senior Frontend Developer &mdash; Lead</p>
            <span class="experience-item__dates">Apr 2025 &ndash; Present &middot; Montreal</span>
            <p class="experience-item__impact">
              Set technical direction for the front-end team. React, TypeScript, GraphQL.
              Daily code reviews, sprint ownership, and mentoring across experience levels.
            </p>
          </article>

          <article class="experience-item reveal">
            <span class="experience-item__number">Role 07</span>
            <h2 class="experience-item__company">Turbulent</h2>
            <p class="experience-item__role">Frontend Developer</p>
            <span class="experience-item__dates">Oct 2022 &ndash; Apr 2025 &middot; 2 yrs 7 mos &middot; Montreal</span>
            <p class="experience-item__impact">
              Built component-driven UIs for robertsspaceindustries.com. Storybook library,
              GraphQL integration, i18n, e-commerce flows. CI/CD with Docker, Webpack, Vite.
            </p>
          </article>

          <article class="experience-item reveal">
            <span class="experience-item__number">Role 06</span>
            <h2 class="experience-item__company">5TW</h2>
            <p class="experience-item__role">Full Stack Developer</p>
            <span class="experience-item__dates">Oct 2017 &ndash; Nov 2022 &middot; 5 yrs 2 mos</span>
            <p class="experience-item__impact">
              Five years across the stack. HTML/CSS/JS, Liquid, Shopify API,
              React, Angular, Node.js, Java/Spring.
            </p>
          </article>

          <article class="experience-item reveal">
            <span class="experience-item__number">Role 05</span>
            <h2 class="experience-item__company">Arduino Workshops</h2>
            <p class="experience-item__role">C Programming &amp; Arduino Instructor</p>
            <span class="experience-item__dates">Jul 2015 &ndash; Dec 2016 &middot; 1 yr 6 mos &middot; São Paulo</span>
            <p class="experience-item__impact">
              Taught robotics programming at Fab Lab Livre SP, PUC-SP, USP, and Red Bull.
            </p>
          </article>

          <article class="experience-item reveal">
            <span class="experience-item__number">Role 04</span>
            <h2 class="experience-item__company">Farfetch</h2>
            <p class="experience-item__role">Technical SEO / JS Consultant</p>
            <span class="experience-item__dates">May 2015 &ndash; Dec 2015 &middot; 8 mos</span>
            <p class="experience-item__impact">
              SEO architecture, keyword strategy, and technical training for content teams.
            </p>
          </article>

          <article class="experience-item reveal">
            <span class="experience-item__number">Role 03</span>
            <h2 class="experience-item__company">Blending Visions</h2>
            <p class="experience-item__role">Co-Founder, Creative Coder</p>
            <span class="experience-item__dates">May 2014 &ndash; May 2015 &middot; 1 yr 1 mo &middot; São Paulo</span>
            <p class="experience-item__impact">
              VR/AR experiences, projection mapping, interactive installations, immersive web.
            </p>
          </article>

          <article class="experience-item reveal">
            <span class="experience-item__number">Role 02</span>
            <h2 class="experience-item__company">Brainstorm #9</h2>
            <p class="experience-item__role">Freelance Copywriter / Content Specialist</p>
            <span class="experience-item__dates">Dec 2012 &ndash; Dec 2016 &middot; 4 yrs 1 mo &middot; São Paulo</span>
            <p class="experience-item__impact">
              In-depth articles for a publication with 1.3M unique visitors/month.
              Trend forecasting, interviews, content strategy.
            </p>
          </article>

          <article class="experience-item reveal">
            <span class="experience-item__number">Role 01</span>
            <h2 class="experience-item__company">Gaia Creative</h2>
            <p class="experience-item__role">Digital Marketing Coordinator</p>
            <span class="experience-item__dates">May 2010 &ndash; Oct 2012 &middot; 2 yrs 6 mos &middot; São Paulo</span>
            <p class="experience-item__impact">
              Inbound, PPC, SEO, and content for BMW, Endeavor, SEBRAE, Hospital Albert Einstein.
            </p>
          </article>

        </div>
      </div>
    </section>

    <!-- ================================================================
         PROJECTS
         ================================================================ -->
    <section class="section" data-section="projects">
      <div class="section__content">
        <span class="section__label reveal">Projects</span>

        <article class="project-card reveal">
          <span class="project-card__label">Project: Recordoc</span>
          <h2 class="project-card__name">Recordoc</h2>
          <a href="https://recordoc.app" class="project-card__url" target="_blank" rel="noopener noreferrer">
            recordoc.app<span class="sr-only"> (opens in new tab)</span>
          </a>
          <p class="project-card__desc">
            Record a video. Get a professional document. Gemini 2.5 Flash transcribes,
            structures, and formats across 17 templates. DB-driven job queue with
            SELECT FOR UPDATE SKIP LOCKED. Resumable uploads. API envelope pattern.
          </p>
          <p class="project-card__stack">
            <span class="project-card__stack-label">Stack:</span>
            React &middot; Vite &middot; Express &middot; Drizzle &middot; PostgreSQL &middot; Supabase &middot; Turborepo &middot; Docker
          </p>
        </article>

        <article class="project-card reveal">
          <span class="project-card__label">Project: Surpride</span>
          <h2 class="project-card__name">Surpride</h2>
          <p class="project-card__desc">
            Full business automation for an Etsy pride merch store. Real-time IMAP
            email parsing, Printful webhook integration, integer-cents financial system.
            Eleven Claude Code skills replace traditional application features entirely.
          </p>
          <p class="project-card__stack">
            <span class="project-card__stack-label">Stack:</span>
            Fastify &middot; SQLite &middot; React &middot; Tailwind &middot; Docker &middot; Caddy
          </p>
        </article>

        <article class="project-card reveal">
          <span class="project-card__label">Project: FinCherry</span>
          <h2 class="project-card__name">FinCherry</h2>
          <p class="project-card__desc">
            Personal finance dashboard handling three currencies (CAD/BRL/EUR).
            Six bank PDF parsers, Gemini with PII stripping for auto-categorization,
            what-if scenarios. Type-safe tRPC end-to-end.
          </p>
          <p class="project-card__stack">
            <span class="project-card__stack-label">Stack:</span>
            React &middot; Vite &middot; Fastify &middot; tRPC &middot; Drizzle &middot; PostgreSQL &middot; Docker
          </p>
        </article>

        <article class="project-card reveal">
          <span class="project-card__label">Project: CherryAgent</span>
          <h2 class="project-card__name">CherryAgent</h2>
          <p class="project-card__desc">
            Self-hosted AI automation platform. Telegram interface, agent loop architecture,
            tiered model routing. Voice coding that produces GitHub PRs. Distributed task
            sync across devices. Under $5/month in AI spend on a $10/month VPS.
          </p>
          <p class="project-card__stack">
            <span class="project-card__stack-label">Stack:</span>
            Fastify &middot; PostgreSQL &middot; Redis &middot; BullMQ &middot; pnpm monorepo &middot; Docker
          </p>
        </article>

      </div>
    </section>

    <!-- ================================================================
         SKILLS
         ================================================================ -->
    <section class="section" data-section="skills">
      <div class="section__content">
        <span class="section__label reveal">Capabilities</span>

        <div class="skills-grid reveal">
          <div class="skills-domain">
            <h2 class="skills-domain__title">Languages</h2>
            <p class="skills-domain__list">
              TypeScript, JavaScript, HTML, CSS, Java, Python
            </p>
          </div>

          <div class="skills-domain">
            <h2 class="skills-domain__title">Frontend</h2>
            <p class="skills-domain__list">
              React, Angular, Next.js, Storybook, SASS, Tailwind, Three.js, WebGL
            </p>
          </div>

          <div class="skills-domain">
            <h2 class="skills-domain__title">Backend</h2>
            <p class="skills-domain__list">
              Node.js, Fastify, Express, Nest.js, GraphQL, tRPC, Spring
            </p>
          </div>

          <div class="skills-domain">
            <h2 class="skills-domain__title">Data</h2>
            <p class="skills-domain__list">
              PostgreSQL, MongoDB, MySQL, SQLite, Redis, Drizzle ORM
            </p>
          </div>

          <div class="skills-domain">
            <h2 class="skills-domain__title">Infrastructure</h2>
            <p class="skills-domain__list">
              Docker, Linux, Nginx, CI/CD, Webpack, Vite, Turborepo, Git
            </p>
          </div>

          <div class="skills-domain">
            <h2 class="skills-domain__title">Hardware</h2>
            <p class="skills-domain__list">
              Arduino, sensors, interactive installations
            </p>
          </div>

          <div class="skills-domain">
            <h2 class="skills-domain__title">Spoken</h2>
            <p class="skills-domain__list">
              English, Portuguese, Spanish, French
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================
         EDUCATION & HONORS
         ================================================================ -->
    <section class="section" data-section="appendix">
      <div class="section__content">
        <span class="section__label reveal">Appendix</span>

        <div class="appendix-grid reveal">

          <!-- Education -->
          <div>
            <h2 class="section__label" style="margin-bottom: var(--space-md)">Education</h2>

            <div class="appendix-item">
              <p class="appendix-item__title">Postgraduate &mdash; Software Engineering</p>
              <p class="appendix-item__institution">PUC Minas</p>
              <span class="appendix-item__date">2020 &ndash; 2021</span>
            </div>

            <div class="appendix-item">
              <p class="appendix-item__title">Master's &mdash; Intelligence Technology &amp; Digital Design</p>
              <p class="appendix-item__institution">PUC São Paulo</p>
              <span class="appendix-item__date">2013 &ndash; 2015</span>
            </div>

            <div class="appendix-item">
              <p class="appendix-item__title">Semester Abroad &mdash; Fine Art, Contemporary Practice</p>
              <p class="appendix-item__institution">University of the Arts London</p>
              <span class="appendix-item__date">2012</span>
            </div>

            <div class="appendix-item">
              <p class="appendix-item__title">Bachelor's &mdash; Communication &amp; Marketing</p>
              <p class="appendix-item__institution">ESPM</p>
              <span class="appendix-item__date">2007 &ndash; 2010</span>
            </div>
          </div>

          <!-- Honors & Certifications -->
          <div>
            <h2 class="section__label" style="margin-bottom: var(--space-md)">Honors &amp; Certifications</h2>

            <div class="appendix-item">
              <p class="appendix-item__title">Maker in Residence</p>
              <p class="appendix-item__institution">Red Bull Basement</p>
              <span class="appendix-item__date">2016</span>
            </div>

            <div class="appendix-item">
              <p class="appendix-item__title">Financial Support Award</p>
              <p class="appendix-item__institution">Red Bull Digital Academy</p>
              <span class="appendix-item__date">2014</span>
            </div>

            <div class="appendix-item">
              <p class="appendix-item__title">
                Artist in Residence
                <span class="redact" role="img" aria-label="Museu da Imagem e do Som">
                  <span class="redact__text">&mdash; Museu da Imagem e do Som</span>
                  <span class="redact__bar" aria-hidden="true"></span>
                </span>
              </p>
              <p class="appendix-item__institution">LabMIS, São Paulo</p>
              <span class="appendix-item__date">2013</span>
            </div>

            <div class="appendix-item">
              <p class="appendix-item__title">Published Author</p>
              <p class="appendix-item__institution">Laboratório Aché</p>
              <span class="appendix-item__date">2011</span>
            </div>

            <div class="appendix-item">
              <p class="appendix-item__title">Graph Developer Associate</p>
              <p class="appendix-item__institution">Apollo GraphQL</p>
            </div>

            <div class="appendix-item">
              <p class="appendix-item__title">Linux System Administration &amp; DevOps</p>
              <p class="appendix-item__institution">4Linux</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ================================================================
         CONTACT
         ================================================================ -->
    <footer class="contact" data-section="contact">
      <div class="section__content">
        <span class="section__label reveal">Contact</span>
        <a href="mailto:samantafluture@gmail.com" class="contact__email reveal">
          samantafluture@gmail.com
        </a>
        <div class="contact__links reveal">
          <a href="https://github.com/samantafluture" class="contact__link" target="_blank" rel="noopener noreferrer">
            GitHub<span class="sr-only"> (opens in new tab)</span>
          </a>
          <a href="https://linkedin.com/in/samantafluture" class="contact__link" target="_blank" rel="noopener noreferrer">
            LinkedIn<span class="sr-only"> (opens in new tab)</span>
          </a>
        </div>
        <p class="contact__endfile reveal">End of file.</p>
      </div>
    </footer>

  </div>
</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
