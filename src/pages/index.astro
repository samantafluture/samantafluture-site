---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TerminalPrompt from '../components/TerminalPrompt.astro';
import AboutCard from '../components/AboutCard.astro';
import NowSection from '../components/NowSection.astro';
import StreamEntry from '../components/StreamEntry.astro';
import StreamFilters from '../components/StreamFilters.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SubscribeCTA from '../components/SubscribeCTA.astro';
import Footer from '../components/Footer.astro';

const allStream = await getCollection('stream', ({ data }) => !data.draft);
const sortedStream = allStream.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Samanta Fluture — Frontend Lead & Builder"
  description="Frontend lead at Turbulent. Building AI-first products, writing about leadership and dev life. React, TypeScript, GraphQL."
  activeTab="about"
>
  <div class="content-area">

    <!-- About -->
    <section class="section" id="about">
      <TerminalPrompt command="whoami" showPath />
      <AboutCard />
    </section>

    <!-- Now -->
    <section class="section" id="now">
      <TerminalPrompt command="cat now.md" />
      <NowSection />
    </section>

    <!-- Stream -->
    <section class="section" id="stream">
      <TerminalPrompt command="stream --latest" />
      <h2 class="reveal" style="margin-bottom: var(--space-lg);">Stream</h2>
      <StreamFilters />
      <div class="stream-list">
        {sortedStream.map((entry, i) => (
          <>
            <StreamEntry
              type={entry.data.type}
              title={entry.data.title}
              date={entry.data.date}
              project={entry.data.project}
              excerpt={entry.data.excerpt}
              slug={entry.id}
            />
            {i === 3 && <SubscribeCTA />}
          </>
        ))}
      </div>
    </section>

    <!-- Projects -->
    <section class="section" id="projects">
      <TerminalPrompt command="ls ~/projects" />
      <h2 class="reveal" style="margin-bottom: var(--space-lg);">Projects</h2>
      <div class="projects-grid">
        {sortedProjects.map((project) => (
          <ProjectCard
            name={project.data.name}
            description={project.data.description}
            stack={project.data.stack}
            url={project.data.url}
            repo={project.data.repo}
          />
        ))}
      </div>
    </section>

    <!-- Subscribe -->
    <section class="section" id="subscribe">
      <SubscribeCTA />
    </section>

    <!-- Footer -->
    <Footer />

  </div>
</BaseLayout>
