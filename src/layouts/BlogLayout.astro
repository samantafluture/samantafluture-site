---
import BaseLayout from './BaseLayout.astro';
import Footer from '../components/Footer.astro';
import SubscribeCTA from '../components/SubscribeCTA.astro';
import { ArrowLeft, FileText } from '@lucide/astro';

interface Props {
  title: string;
  description: string;
  date: Date;
}

const { title, description, date } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — Samanta Fluture`} description={description} ogType="article">
  <div class="content-area">
    <div class="section">
      <a href="/" class="blog-back">
        <ArrowLeft size={14} />
        BACK TO STREAM
      </a>

      <header class="blog-header">
        <div class="blog-header__meta">
          <span class="stream-entry__badge stream-entry__badge--writing">
            <FileText size={12} />
            WRITING
          </span>
          <time class="stream-entry__date" datetime={date.toISOString()}>
            {formattedDate}
          </time>
        </div>
        <h1 class="blog-header__title">{title}</h1>
      </header>

      <div class="blog-body prose prose--large">
        <slot />
      </div>

      <div class="blog-footer">
        <a href="/" class="blog-back">
          <ArrowLeft size={14} />
          BACK TO STREAM
        </a>
        <SubscribeCTA />
      </div>
    </div>

    <Footer />
  </div>
</BaseLayout>
