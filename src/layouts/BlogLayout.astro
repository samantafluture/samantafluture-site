---
import BaseLayout from './BaseLayout.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
}

const { title, description, date, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — Samanta Fluture`} description={description}>
  <div class="blog-post">
    <a href="/blog/" class="blog-post__back">&larr; BACK TO BLOG</a>

    <header class="blog-post__header">
      {tags.length > 0 && (
        <p class="blog-post__tag">{tags[0].toUpperCase()}</p>
      )}
      <h1 class="blog-post__title">{title}</h1>
      <time class="blog-post__date" datetime={date.toISOString()}>
        {formattedDate}
      </time>
    </header>

    <article class="blog-post__content prose">
      <slot />
    </article>

    <a href="/blog/" class="blog-post__back blog-post__back--bottom">&larr; BACK TO BLOG</a>
  </div>

  <div class="page">
    <Footer />
  </div>
</BaseLayout>

<style>
  .blog-post {
    max-width: 680px;
    margin: 0 auto;
    padding: calc(var(--space-xl) + 2rem) var(--gutter) var(--space-xl);
    position: relative;
    z-index: 1;
  }

  .blog-post__back {
    font-family: var(--font-mono);
    font-size: var(--text-cta);
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-body);
    transition: color var(--duration-fast) var(--ease-out);
    display: inline-block;
  }

  .blog-post__back:hover {
    color: var(--accent);
  }

  .blog-post__back--bottom {
    margin-top: var(--space-xl);
  }

  .blog-post__header {
    margin-top: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .blog-post__tag {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: var(--space-sm);
  }

  .blog-post__title {
    font-family: var(--font-heading);
    font-size: var(--text-h1);
    font-weight: 700;
    color: var(--text-heading);
    line-height: 1.1;
    margin-bottom: var(--space-sm);
  }

  .blog-post__date {
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    color: var(--text-muted);
  }

  /* Prose — blog reading typography */
  .prose {
    font-family: var(--font-reading);
    font-size: var(--text-reading);
    line-height: 1.7;
    color: var(--text-heading);
  }

  .prose :global(p) {
    margin-bottom: 1.5em;
  }

  .prose :global(h2) {
    font-family: var(--font-heading);
    font-size: var(--text-h2);
    font-weight: 600;
    color: var(--text-heading);
    line-height: 1.2;
    margin-top: 2.5em;
    margin-bottom: 0.75em;
  }

  .prose :global(h3) {
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    font-weight: 600;
    color: var(--text-heading);
    line-height: 1.3;
    margin-top: 2em;
    margin-bottom: 0.5em;
  }

  .prose :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .prose :global(a:hover) {
    color: var(--accent-hover);
  }

  .prose :global(strong) {
    font-weight: 600;
    color: var(--text-heading);
  }

  .prose :global(em) {
    font-style: italic;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: var(--space-sm);
    margin-block: 1.5em;
    color: var(--text-body);
    font-style: italic;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.5em;
    padding-left: 1.5em;
  }

  .prose :global(ul) {
    list-style: disc;
  }

  .prose :global(ol) {
    list-style: decimal;
  }

  .prose :global(li) {
    margin-bottom: 0.5em;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--bg-card-dark);
    border: 1px solid var(--border-subtle);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    color: var(--text-heading);
  }

  .prose :global(pre) {
    background: var(--bg-card-dark);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    padding: var(--space-sm);
    overflow-x: auto;
    margin-bottom: 1.5em;
  }

  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 14px;
    line-height: 1.6;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border-subtle);
    margin-block: 2em;
  }

  .prose :global(img) {
    border-radius: 8px;
    margin-block: 1.5em;
  }
</style>
