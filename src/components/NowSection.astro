---
import { Zap, Wrench, PenLine, Rocket, BookOpen } from '@lucide/astro';
import matter from 'gray-matter';
import fs from 'node:fs';
import path from 'node:path';

const nowPath = path.join(process.cwd(), 'src/content/now.md');
const nowFile = fs.readFileSync(nowPath, 'utf-8');
const { data } = matter(nowFile);

const entries = data.entries as Array<{ key: string; value: string }>;
const updated = new Date(data.updated).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const iconMap: Record<string, any> = {
  building: Wrench,
  writing: PenLine,
  shipping: Rocket,
  learning: BookOpen,
};
---

<div class="card reveal">
  <h2 class="now__heading">
    <Zap size={18} />
    What I'm up to
  </h2>

  <div class="now__entries">
    {entries.map((entry) => {
      const Icon = iconMap[entry.key] || Zap;
      return (
        <div class="now__entry">
          <span class="now__key">
            <Icon size={14} />
            {entry.key}
          </span>
          <span class="now__value">{entry.value}</span>
        </div>
      );
    })}
  </div>

  <p class="now__updated">Updated {updated}</p>
</div>
