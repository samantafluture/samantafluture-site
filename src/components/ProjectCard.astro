---
interface Props {
  name: string;
  description: string;
  tech: string;
  url?: string;
}

const { name, description, tech, url } = Astro.props;
---

<article class="project-card reveal">
  <h3 class="project-card__name">{name}</h3>
  <p class="project-card__desc">{description}</p>
  <p class="project-card__tech">{tech}</p>
  {url ? (
    <a href={url} class="project-card__cta" target="_blank" rel="noopener noreferrer">
      VIEW PROJECT <span aria-hidden="true">&rarr;</span>
      <span class="sr-only">(opens in new tab)</span>
    </a>
  ) : (
    <span class="project-card__cta" style="color: var(--text-muted);">
      COMING SOON
    </span>
  )}
</article>
