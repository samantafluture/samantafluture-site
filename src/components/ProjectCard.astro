---
import { ArrowRight } from '@lucide/astro';

interface Props {
  name: string;
  description: string;
  stack: string;
  url?: string;
  repo?: string;
}

const { name, description, stack, url, repo } = Astro.props;
const href = url || repo;
---

<article class="project-card reveal">
  <h3 class="project-card__name">{name}</h3>
  <p class="project-card__desc">{description}</p>
  <p class="project-card__stack">{stack}</p>
  {href ? (
    <a href={href} class="project-card__link" target="_blank" rel="noopener noreferrer">
      VIEW PROJECT <ArrowRight size={14} />
      <span class="sr-only">(opens in new tab)</span>
    </a>
  ) : (
    <span class="project-card__link" style="color: var(--text-muted); cursor: default;">
      COMING SOON
    </span>
  )}
</article>
