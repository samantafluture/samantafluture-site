---
import { Github, Linkedin, Mail, ArrowUp } from '@lucide/astro';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__left">
      <p class="footer__left-name">samantafluture</p>
      <p class="footer__left-location">Montreal, Canada <img src="https://cdn.jsdelivr.net/gh/twitter/twemoji@14.0.2/assets/svg/1f1e8-1f1e6.svg" alt="Canadian flag" width="16" height="16" style="display:inline;vertical-align:-2px;" /><img src="https://cdn.jsdelivr.net/gh/twitter/twemoji@14.0.2/assets/svg/1f1e7-1f1f7.svg" alt="Brazilian flag" width="16" height="16" style="display:inline;vertical-align:-2px;margin-left:4px;" /></p>
    </div>
    <div class="footer__right">
      <a href="https://github.com/samantafluture" class="footer__link" target="_blank" rel="noopener noreferrer">
        <Github size={14} />
        GitHub
      </a>
      <a href="https://linkedin.com/in/samantafluture" class="footer__link" target="_blank" rel="noopener noreferrer">
        <Linkedin size={14} />
        LinkedIn
      </a>
      <a href="mailto:samantafluture@gmail.com" class="footer__link">
        <Mail size={14} />
        Email
      </a>
    </div>
  </div>
  <div class="footer__bottom-row">
    <p class="footer__bottom">&copy; {year} &middot; Built with Astro, caffeine, and too many side projects</p>
    <a href="/#about" class="footer__back-top" aria-label="Back to top">
      <ArrowUp size={14} />
    </a>
  </div>
</footer>
