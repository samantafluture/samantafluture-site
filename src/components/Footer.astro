---
import SectionLabel from './SectionLabel.astro';

const year = new Date().getFullYear();
---

<footer class="footer">
  <SectionLabel label="Footer" />

  <div class="footer__grid">
    <div>
      <p class="footer__column-title">Navigation</p>
      <a href="/#about" class="footer__link">About</a>
      <a href="/#projects" class="footer__link">Projects</a>
      <a href="/blog/" class="footer__link">Blog</a>
    </div>

    <div>
      <p class="footer__column-title">Social</p>
      <a href="https://github.com/samantafluture" class="footer__link" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://linkedin.com/in/samantafluture" class="footer__link" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href="mailto:samantafluture@gmail.com" class="footer__link">Email</a>
    </div>
  </div>

  <p class="footer__copy">samantafluture &copy; {year}</p>
</footer>
