---
import { Mail, ArrowRight } from '@lucide/astro';
---

<div class="subscribe-cta reveal">
  <h2>
    <Mail size={20} />
    Want to follow along?
  </h2>
  <p class="subscribe-cta__desc">
    Updates on what I'm building, writing about frontend leadership, and notes
    from the intersection of AI and product development. No spam, no schedule. On Substack.
  </p>
  <a href="https://samantafluture.substack.com/" class="subscribe-cta__btn" target="_blank" rel="noopener noreferrer">
    SUBSCRIBE <ArrowRight size={14} />
  </a>
</div>
